# Optional override (defaults to the Raylase Hygraph project Content API)
# NEXT_PUBLIC_HYGRAPH_ENDPOINT=https://api-eu-central-1-shared-euc1-02.hygraph.com/v2/cmn4iwrhg004i07uztuwdxz30/master

# Production reads: token with default stage PUBLISHED (create in Hygraph: Project Settings → Access → API Access)
PRODUCTION_TOKEN=

# Live preview / draft reads: token with default stage DRAFT (same place; enable read permissions for draft content)
PREVIEW_TOKEN=

# Shared secret for /api/draft?secret=... (must match the `secret` query param in your Hygraph Preview widget URL template)
PREVIEW_SECRET=

# Legacy alias for PRODUCTION_TOKEN (optional)
# HYGRAPH_TOKEN=
